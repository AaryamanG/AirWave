    "pause_palm_seconds": 1.0
  },
  "mappings": {
    "pinch_index": "left_click",
    "pinch_middle": "right_click",
    "pinch_ring": "middle_click",
    "pinch_pinky": "screenshot",
    "two_finger_up_down": "scroll",
    "open_palm_timeout": "pause_tracking"
  }
